APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# Production: APP_DEBUG=false (không lộ stack trace / chi tiết lỗi)
APP_DEBUG=true
APP_URL=http://localhost
FRONTEND_URL=http://localhost:5173

# JWT (php artisan jwt:secret để sinh key mới — không commit .env)
JWT_SECRET=

# Security headers / CSP (API middleware). local = Report-Only; production = enforce
SECURITY_CSP_ENABLED=true

# Password policy (production: bật uncompromised nếu server có outbound HTTPS)
PASSWORD_MIN_LENGTH=8
PASSWORD_UNCOMPROMISED=false

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Production: warning hoặc error
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
SESSION_DRIVER=file

# Booking API rate limits (requests per minute)
BOOKING_SLOTS_RATE_LIMIT=60
BOOKING_CREATE_RATE_LIMIT=10
BOOKING_MUTATE_RATE_LIMIT=20
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# 10 MB
UPLOAD_MAX_SIZE_KB=10240
# 20 upload/phút
UPLOAD_RATE_LIMIT=20
